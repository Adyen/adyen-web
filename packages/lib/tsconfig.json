{
    "compilerOptions": {
        /* Library declaration */
        "declaration": true,
        "outDir": "./dist/temp-types",

        /* Using bundler as we are transpiling with SWC */
        "moduleResolution": "Bundler",
        "module": "ESNext",

        /* Base Options: */
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "target": "es2022",
        "allowJs": true,
        "resolveJsonModule": true,
        "moduleDetection": "force",

        /* Strictness */
        "strict": true,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "strictBindCallApply": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictPropertyInitialization": true,
        "useDefineForClassFields": true,

        /** Preact */
        "jsx": "react",
        "jsxFactory": "h",

        /* Include types for the browser: window, document, etc */
        "lib": ["es2022", "dom", "dom.iterable"],

        "types": ["@testing-library/jest-dom", "applepayjs", "googlepay", "node"]
    },
    "include": ["./src/**/*", "./storybook/**/*"],
    "exclude": ["node_modules", "./dist/**", "**/*.scss", "**/*_*/**"]
}
